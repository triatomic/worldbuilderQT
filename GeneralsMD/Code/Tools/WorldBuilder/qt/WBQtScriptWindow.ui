<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>WBQtScriptWindow</class>
 <widget class="QWidget" name="WBQtScriptWindow">
  <property name="windowTitle">
   <string>Script Editor</string>
  </property>
  <layout class="QVBoxLayout" name="rootLayout" stretch="0,0,0,1,0,0,0">
   <item>
    <widget class="QGroupBox" name="optBox">
     <property name="title">
      <string>Options</string>
     </property>
     <layout class="QGridLayout" name="optGrid">
      <item row="0" column="0">
       <widget class="QCheckBox" name="ckCompress">
        <property name="toolTip">
         <string>Save scripts compressed in the map file (smaller maps).</string>
        </property>
        <property name="text">
         <string>Compress Script</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QCheckBox" name="ckNewIcons">
        <property name="toolTip">
         <string>Modern tree icons. Always on in the Qt editor.</string>
        </property>
        <property name="text">
         <string>New Icons</string>
        </property>
       </widget>
      </item>
      <item row="0" column="2">
       <widget class="QCheckBox" name="ckCleanName">
        <property name="toolTip">
         <string>Hide the [E N H] difficulty tag on scripts that run on all three difficulties.</string>
        </property>
        <property name="text">
         <string>Clean Script Name</string>
        </property>
       </widget>
      </item>
      <item row="0" column="3">
       <widget class="QCheckBox" name="ckAutoVerify">
        <property name="toolTip">
         <string>Re-check scripts for warnings (red) automatically after every edit.</string>
        </property>
        <property name="text">
         <string>Auto Verify</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QCheckBox" name="ckSmartCopy">
        <property name="toolTip">
         <string>Copy auto-increments numbers in the script's parameters (Counter01 → Counter02).</string>
        </property>
        <property name="text">
         <string>Smart Copy</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QCheckBox" name="ckFastLoad">
        <property name="toolTip">
         <string>Open the editor faster on big script sets by skipping the deep warning-hint scan.</string>
        </property>
        <property name="text">
         <string>Fast Load</string>
        </property>
       </widget>
      </item>
      <item row="1" column="2">
       <widget class="QCheckBox" name="ckScriptMerge">
        <property name="toolTip">
         <string>Ctrl+drag a script or folder onto another to merge them. Plain drag still moves.</string>
        </property>
        <property name="text">
         <string>Script Merge</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0" colspan="2">
       <widget class="QCheckBox" name="ckRefByParam">
        <property name="toolTip">
         <string>Find [Referenced in] by scanning actual script parameters instead of plain text.</string>
        </property>
        <property name="text">
         <string>Detect References via picked Parameters</string>
        </property>
       </widget>
      </item>
      <item row="2" column="2" colspan="2">
       <widget class="QCheckBox" name="ckDisableRef">
        <property name="toolTip">
         <string>Skip the [Referenced in] scan on selection. Faster on huge script sets.</string>
        </property>
        <property name="text">
         <string>Disable references (reduces input lag)</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
